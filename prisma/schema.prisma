// INKII — Datenbankmodell
// PostgreSQL — für lokale Entwicklung und Produktion (Vercel) identisch.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  subtitle    String   @default("")
  description String   @default("")
  icon        String   @default("box")
  priceCents  Int?     // null = "Preis auf Anfrage"
  priceTiers  String   @default("[]") // JSON: [{qty:15,cents:1491},{qty:50,cents:1349}]
  sizes       String   @default("[]") // JSON: [{name:"S",extraCents:0},{name:"XXL",extraCents:90}]
  stock       Int      @default(0)
  minOrderQty Int      @default(1) // Mindestbestellmenge (z.B. 25 Stück)
  status      String   @default("active") // active | draft
  isNew       Boolean  @default(false)
  isEco       Boolean  @default(false)
  colors      String   @default("") // kommagetrennt, z. B. "blau,schwarz"
  material    String   @default("") // kommagetrennt, z. B. "metall,kunststoff"
  images      String   @default("") // kommagetrennte Bild-URLs (max. 15)
  colorImages String   @default("{}") // JSON: { "weiss": ["url1","url2"], ... }
  careSymbols String   @default("") // kommagetrennte Pflegesymbole: "wash-30,no-bleach,iron-low"
  displayOrder Int     @default(0) // Anzeige-Reihenfolge im Katalog (höher = oben)
  cardFit     String   @default("cover") // legacy
  cardCrop    String   @default("") // JSON: {"zoom":1.2,"x":0,"y":-15} — Zoom & Pan für Vitrin-Bild
  visiblePages String  @default("[]")
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  company   String   @default("")
  subject   String
  message   String   @default("")
  status    String   @default("new") // new | progress | done
  createdAt DateTime @default(now())
}

// Hochgeladene Bilder/Videos für Startseite, Bereiche & Hero.
// key = Slot-ID (z. B. "cat-1", "area-1", "nh-hero") oder "hero-video".
model SiteImage {
  key       String   @id
  url       String
  updatedAt DateTime @updatedAt
}

// Team-Mitglieder für die "Über Uns"-Seite.
// Admin verwaltet Abteilung, Name, Rolle, E-Mail und Foto.
model TeamMember {
  id         String   @id @default(cuid())
  department String   // Pflicht: Hauptzeile (z. B. "Grafik & Design")
  name       String   @default("")  // optional: Person (z. B. "Anna Müller")
  role       String   @default("")  // optional: Untertitel (z. B. "Layout & Datencheck")
  email      String   @default("")
  photoUrl   String   @default("")  // Vercel-Blob-URL
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}

// Header-Navigation: pro Schlüssel ein Eintrag. Wenn keine Zeile existiert,
// gilt der Eintrag als aktiv (Standard für frische Installation).
model NavSetting {
  key       String  @id            // z. B. "home", "werbemittel"
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}

// ============================================================
// SHOP / E-COMMERCE MODELLE
// ============================================================

// Kunde (Customer) — sowohl B2C als auch B2B
model Customer {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String?  // optional - Gast-Checkout möglich
  firmname        String   @default("") // B2B Firma
  ustId           String   @default("") // USt-IdNr. (VAT)
  salutation      String   @default("") // Herr / Frau / Divers
  firstName       String
  lastName        String
  phone           String   @default("")
  // Rechnungsadresse:
  billingStreet   String
  billingCity     String
  billingZip      String
  billingCountry  String   @default("DE")
  // Lieferadresse (falls abweichend):
  shippingStreet  String   @default("")
  shippingCity    String   @default("")
  shippingZip     String   @default("")
  shippingCountry String   @default("DE")
  shippingDiffers Boolean  @default(false)
  notes           String   @default("") // Admin-Notizen
  acceptsMarketing Boolean @default(false)
  isGuest         Boolean  @default(true) // Gast-Checkout
  isActive        Boolean  @default(true) // Deaktivierung (soft-delete)
  emailVerified   Boolean  @default(false)
  verificationCode String  @default("")
  verificationCodeExpiresAt DateTime?
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Bestellung (Order)
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique  // INKI-2026-00001
  customer        Customer    @relation(fields: [customerId], references: [id])
  customerId      String
  status          String      @default("NEU")
  // NEU, WARTEND, BEZAHLT, IN_PRODUKTION, VERSANDBEREIT,
  // VERSENDET, ZUGESTELLT, ABGESCHLOSSEN, STORNIERT, RUECKERSTATTET
  items           OrderItem[]
  // Beträge in Cents
  subtotalCents   Int         @default(0)
  taxCents        Int         @default(0)
  taxRate         Float       @default(19.0)
  shippingCents   Int         @default(0)
  discountCents   Int         @default(0)
  totalCents      Int         @default(0)
  // Zahlung
  paymentMethod   String      @default("") // paypal, klarna, rechnung
  paymentStatus   String      @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  paymentRef      String      @default("") // PayPal/Klarna Transaction ID
  paidAt          DateTime?
  // PayPal
  paypalOrderId   String      @default("")
  paypalCaptureId String      @default("")
  // Stripe (Klarna)
  stripeSessionId String      @default("")
  stripePaymentIntentId String @default("")
  // Versand
  shippingCarrier String      @default("") // DHL, DPD, Hermes, GLS, UPS
  trackingNumber  String      @default("")
  shippedAt       DateTime?
  deliveredAt     DateTime?
  // Notizen
  customerNote    String      @default("") // Vom Kunden
  adminNote       String      @default("") // Intern
  // Rechnung
  invoiceUrl      String      @default("") // PDF Rechnung URL
  invoiceNumber   String      @default("")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// OrderItem — einzelne Position einer Bestellung
model OrderItem {
  id              String   @id @default(cuid())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  // Produkt-Snapshot (Name & Code zum Bestellzeitpunkt)
  productId       String
  productName     String
  productCode     String
  productImage    String   @default("")
  // Variante
  color           String   @default("")
  size            String   @default("")
  quantity        Int      @default(1)
  unitPriceCents  Int      @default(0)
  // DTF Druck (optional)
  hasDtf          Boolean  @default(false)
  dtfDesignUrl    String   @default("") // Hochgeladene Design-Datei
  dtfSize         String   @default("") // "15x15", "20x20", "30x30"
  dtfPriceCents   Int      @default(0)
  // Total = (unitPriceCents + dtfPriceCents) * quantity
  lineTotalCents  Int      @default(0)
}

// Konfiguration der Zahlungsmethoden (Admin-Toggle)
model PaymentMethod {
  id          String   @id @default(cuid())
  key         String   @unique  // "paypal", "klarna", "rechnung"
  label       String              // Anzeige-Name
  description String   @default("")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  config      String   @default("{}") // JSON für API-Keys etc.
}

// DTF-Druckpreise (Admin pflegt Größen + Preise)
model DtfPrice {
  id         String  @id @default(cuid())
  sizeLabel  String  @unique  // "15x15", "20x20", "30x30"
  widthCm    Int
  heightCm   Int
  priceCents Int
  enabled    Boolean @default(true)
  sortOrder  Int     @default(0)
}

// Versand-Einstellungen
model ShippingConfig {
  id                  String   @id @default(cuid())
  freeShippingFromCents Int    @default(10000) // 100€
  standardCostCents   Int      @default(599)   // 5.99€
  carrier             String   @default("DHL")
  notes               String   @default("")
  transferPriceCents  Int      @default(900)   // DTF Transfer pro Seite (9€)
  updatedAt           DateTime @updatedAt
}

// CompanyInfo — Rechnungs- & Impressums-Daten (singleton)
model CompanyInfo {
  id          String   @id @default(cuid())
  name        String   @default("INKII WORKS")
  owner       String   @default("Sener Kirli")
  street      String   @default("Westuferstr. 25")
  zip         String   @default("45356")
  city        String   @default("Essen")
  country     String   @default("Deutschland")
  phone       String   @default("+49 160 6767001")
  email       String   @default("info@inkiiworks.de")
  web         String   @default("www.inkiiworks.de")
  ustId       String   @default("DE353055316")
  taxNumber   String   @default("")
  // Bank
  bankName    String   @default("")
  iban        String   @default("")
  bic         String   @default("")
  // Rechnungseinstellungen
  taxRate     Int      @default(19) // %
  paymentTermDays Int  @default(14)
  updatedAt   DateTime @updatedAt
}
